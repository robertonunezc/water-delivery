# =============================================================================
# Environment Configuration Template for Water Delivery Multi-Tenant System
# =============================================================================
# Copy this file to .env and update with your production values
# DO NOT commit .env to version control

# =============================================================================
# Environment
# =============================================================================
ENV=prod
# Options: dev, prod
# In prod mode, enables SSL redirects, secure cookies, and HSTS

# =============================================================================
# Django Configuration
# =============================================================================
SECRET_KEY=CHANGEME_django_secret_key_here
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DEBUG=False
# NEVER set to True in production

# =============================================================================
# Database Configuration (PostgreSQL)
# =============================================================================
POSTGRES_DB=water_delivery
POSTGRES_USER=wateruser
POSTGRES_PASSWORD=CHANGEME_secure_password_here
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# =============================================================================
# Redis Configuration
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGEME_redis_password_here

# =============================================================================
# Multi-Tenant Domain Configuration
# =============================================================================
# Replace yourdomain.com with your actual domain
DOMAIN=yourdomain.com

# Allowed hosts (comma-separated, wildcard subdomain support)
ALLOWED_HOSTS=.yourdomain.com,yourdomain.com
# Example: .example.com,example.com allows example.com, *.example.com

# CSRF trusted origins (comma-separated, with protocol)
CSRF_TRUSTED_ORIGINS=https://*.yourdomain.com,https://yourdomain.com
# Include both main domain and wildcard subdomains

# =============================================================================
# SSL/TLS Configuration
# =============================================================================
# Email for Let's Encrypt notifications
LETSENCRYPT_EMAIL=admin@yourdomain.com

# =============================================================================
# Observability (Optional - Uncomment if using Grafana Cloud)
# =============================================================================
# PROMTAIL_LOKI_API_KEY=your_loki_api_key_here
# GRAFANA_CLOUD_URL=https://logs-prod-us-central1.grafana.net

# =============================================================================
# Celery Configuration (Optional)
# =============================================================================
# CELERY_BROKER_URL=redis://redis:6379/0
# CELERY_RESULT_BACKEND=redis://redis:6379/0

# =============================================================================
# Email Configuration (Optional - for production notifications)
# =============================================================================
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your_email@gmail.com
# EMAIL_HOST_PASSWORD=your_app_password

# =============================================================================
# Notes
# =============================================================================
# - All passwords should be strong and unique
# - SECRET_KEY must be kept secret and not shared
# - In development, you can set ENV=dev and DEBUG=True
# - For local development, use DOMAIN=localhost
# - Restart containers after changing environment variables
