{
  "family": "water-delivery-task",
  "networkMode": "bridge",
  "executionRoleArn": "<EXECUTION_ROLE_ARN>",
  "taskRoleArn": "<TASK_ROLE_ARN>",
  "requiresCompatibilities": [
    "EC2"
  ],
  "cpu": "512",
  "memory": "1024",
  "containerDefinitions": [
    {
      "name": "web",
      "image": "<IMAGE>",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "essential": true,
      "environment": [
        { "name": "DJANGO_SETTINGS_MODULE", "value": "water_delivery.settings_production" }
      ],
      "secrets": [
        { "name": "DJANGO_SECRET_KEY", "valueFrom": "<DJANGO_SECRET_ARN>" },
        { "name": "POSTGRES_PASSWORD", "valueFrom": "<POSTGRES_PASSWORD_ARN>" }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/water-delivery",
          "awslogs-region": "<AWS_REGION>",
          "awslogs-stream-prefix": "ecs"
        }
      }
    }
  ]
}
