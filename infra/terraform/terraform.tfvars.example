# Example Terraform vars for `infra/terraform`
# Copy this to `terraform.tfvars` and fill the subnet arrays before running `terraform plan`.

# Required: existing VPC to use
vpc_id = "vpc-07373573170d725a8"

# Provide your public subnet IDs (these are your existing public subnets where ALB and NAT will live)
# Replace the example values with the actual subnet IDs for the AZs you want to use.
public_subnet_ids = [
  "subnet-aaaaaaaaaaaaaaaaa", # us-east-1a
  "subnet-bbbbbbbbbbbbbbbbb", # us-east-1b
  "subnet-ccccccccccccccccc"  # us-east-1c
]

# If you already have private subnets you want to use, list them here. If left empty, Terraform will create private subnets automatically
private_subnet_ids = []

# Optional: explicit CIDR blocks to use for the private subnets that Terraform will create.
# If you prefer Terraform to compute CIDRs from the VPC automatically, leave this empty.
private_subnet_cidrs = [
  "10.0.100.0/24",
  "10.0.101.0/24",
  "10.0.102.0/24"
]

# Project & env
project_name = "water-delivery"
env = "prod"
aws_region = "us-east-1"

# RDS / DB
db_name = "waterdelivery"
db_username = "wateruser"
# db_password can be left empty because use_secrets_manager=true by default (Terraform will generate and store a password in Secrets Manager)
db_password = ""

# Storage and sizing
db_allocated_storage = 20
# Small instance as requested
db_instance_class = "db.t4g.micro"

# Behavior knobs
use_secrets_manager = true
create_private_subnets = true
private_subnets_count = 3
nat_per_az = false

# ECS settings
container_port = 8000
task_cpu = "512"
task_memory = "1024"

# Optional: toggle creation of ECR/ALB
create_ecr = true
create_alb = true

# Notes:
# - Do NOT commit `terraform.tfvars` with real secrets; keep it local or in a secure store.
# - If you set `nat_per_az = true` Terraform will create a NAT gateway per AZ (higher cost), otherwise it will create one NAT in the first public subnet.
# - After copying this file to `terraform.tfvars` and filling the `public_subnet_ids`, run:
#
#   cd infra/terraform
#   terraform init
#   terraform plan
#
# Review the `plan` output carefully before `apply`.
